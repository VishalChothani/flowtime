# Flowtime Environment Variables
# Copy this file to .env and fill in any keys you need

# No API keys required for the current version.
# Flowtime is a fully client-side application.

# Future: if adding AI-powered focus suggestions
# VITE_ANTHROPIC_API_KEY=sk-ant-...
# VITE_OPENAI_API_KEY=sk-...

# Future: if adding ambient sound streaming
# VITE_ELEVENLABS_API_KEY=...

# Future: if adding cloud sync
# VITE_AWS_ACCESS_KEY_ID=...
# VITE_AWS_SECRET_ACCESS_KEY=...
# VITE_AWS_REGION=us-east-1
